# Dependencies
node_modules/

# Build output (dist/viewer is committed intentionally — see README)
packages/viewer/dist/
*.tsbuildinfo

# OS / editor / session-local tooling
.DS_Store
*.local
.claude/

# Logs
npm-debug.log*
*.log

# Raw Terraform state must never land in the repo (it can contain secrets) —
# import it with `npm run tf-import`, which extracts identifiers only.
*.tfstate
*.tfstate.backup
